# Copy to .env.local for local development
# These are exposed to the browser — never put secrets here

# Backend API base URL
VITE_API_URL=http://localhost:8000/api

# false = use the real local backend (required for Astro QA Playwright checks)
VITE_USE_LOCAL_FIXTURES=true

# Production: VITE_API_URL=https://api.yourdomain.com/api

# Support bot username (without @) — Profile screen's "Поддержка" button
# opens t.me/<this> via Telegram WebApp. Leave empty to hide the button.
VITE_SUPPORT_BOT_USERNAME=
