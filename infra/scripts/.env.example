# Copy this file to /opt/astro-tma/.env on the VPS and fill in real values
# before running deploy_vps.sh. Do NOT commit a populated .env.

APP_ENV=production
APP_DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=replace-me-64-hex-chars

# From @BotFather. Rotate via /revoke if leaked.
TELEGRAM_BOT_TOKEN=replace-me-bot-token
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=replace-me-32-hex-chars
TELEGRAM_WEBHOOK_URL=https://your-host/api/payments/webhook

# Postgres password must match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql+asyncpg://astro:REPLACE_ME@postgres:5432/astro_tma
POSTGRES_PASSWORD=REPLACE_ME

REDIS_URL=redis://redis:6379/0
GEONAMES_USERNAME=demo

PRICE_HOROSCOPE_TOMORROW=25
PRICE_HOROSCOPE_WEEK=50
PRICE_HOROSCOPE_MONTH=75
PRICE_TAROT_CELTIC=30
PRICE_TAROT_WEEK=40
PRICE_NATAL_FULL=150
PRICE_SYNASTRY=100
PRICE_SUBSCRIPTION_MONTH=299
PRICE_SUBSCRIPTION_YEAR=1990
PRICE_DESTINY_MATRIX_FULL=150

FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_SYNASTRY=true
